# Off-box backup config (#48). Copy to /etc/scs-backup.env on the box, chmod 600, root-only.
# NEVER commit the real file — this .example carries placeholders only.

# --- restic repository on Backblaze B2 ---
# Format: b2:<bucket-name>:<path-prefix>
RESTIC_REPOSITORY=b2:CHANGE_ME_bucket:scs

# Encryption password for the restic repo. GENERATE A STRONG ONE and ALSO store it in your
# password manager — without it, backups CANNOT be restored (a box loss would lose the key).
RESTIC_PASSWORD=CHANGE_ME_store_this_in_your_password_manager

# Backblaze B2 application key (keyID + applicationKey). Scope the key to the backup bucket.
B2_ACCOUNT_ID=CHANGE_ME_b2_key_id
B2_ACCOUNT_KEY=CHANGE_ME_b2_application_key

# Healthchecks.io check dedicated to the backup job (separate from the app heartbeat).
# The script pings <url>/start, <url> on success, and <url>/fail on error.
HEALTHCHECKS_BACKUP_URL=https://hc-ping.com/CHANGE_ME_backup_check_uuid

# Host path to the scs-data docker volume (default is correct for a standard Docker install).
DATA_PATH=/var/lib/docker/volumes/scs-data/_data
