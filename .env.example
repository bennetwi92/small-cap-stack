# Copy to .env (gitignored) and fill in. Never commit real values.

# IBKR Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4004          # in the compose stack the app reaches Gateway via socat: paper=4004, live=4003.
                        # (Gateway's raw API is 4002/4001 but binds localhost-only w/ TrustedIPs=127.0.0.1.)
IBKR_CLIENT_ID=1
IBKR_TRADING_MODE=paper # paper | live

# Storage (Phase 1: DuckDB + partitioned Parquet on the VPS disk)
DATA_DIR=./data                       # Parquet partitions + DuckDB file live here
DUCKDB_PATH=./data/small_cap_stack.duckdb

# Fundamentals — float source (#109). Free key from financialmodelingprep.com (250 req/day, US
# stocks). Unset → yfinance-only. Quote the value; no spaces/inline comments on this line.
FMP_API_KEY=

# Monitoring
HEALTHCHECKS_PING_URL=
METRICS_PORT=9090

# --- Deployment only (docker-compose / IB Gateway container) ---
# IBKR login for the gnzsnz/ib-gateway container. SET ON THE VPS ONLY — never commit.
TWS_USERID=
TWS_PASSWORD=
READ_ONLY_API=no            # Phase 1 is read-only anyway (no orders); keep 'no' for data/whatIf
AUTO_RESTART_TIME=23:45 PM  # IBC daily Gateway restart (outside the scan window)
# If the username is already logged in elsewhere: manual (block), primary (take over,
# kicks the other session), secondary (yield). Use a dedicated automation username to avoid this.
EXISTING_SESSION_DETECTED_ACTION=manual
TZ=America/New_York
JSON_LOGS=true              # structured JSON logs in production
